# Dhanada Environment Configuration
# Copy to .env and fill in values
#
# All DHANADA_AUTH_* variables are read by the AuthConfig pydantic-settings class.
# DATABASE_URL (without prefix) is read by migrations/env.py and test fixtures.

# Database
# Used by: AuthConfig (DHANADA_AUTH_DATABASE_URL), migrations/env.py (DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dhanada
DHANADA_AUTH_DATABASE_URL=${DATABASE_URL}

# Test Database (optional, overrides default `dhanada_test` on localhost)
# Used by: tests/conftest.py. Keep this separate from DATABASE_URL to
# prevent tests from accidentally touching your dev/production database.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dhanada_test

# --- JWT Configuration ---
# Generate with: openssl rand -base64 32
DHANADA_AUTH_JWT_SECRET_KEY=your-32-char-minimum-secret-key-here
# Key ID for the current signing key. Change during rotation to identify which
# key signed each token so old tokens can still be verified.
DHANADA_AUTH_JWT_KEY_ID=current
# Optional: previous secret keys for token verification during rotation
# DHANADA_AUTH_JWT_PREVIOUS_SECRET_KEYS='["old-key-1","old-key-2"]'
# JWT Algorithm (HS256 recommended)
DHANADA_AUTH_JWT_ALGORITHM=HS256
# Access token lifetime in minutes (default: 15)
DHANADA_AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days (default: 7)
DHANADA_AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Envelope Encryption ---
# Generate with: make generate-kek
# Must be exactly 32 bytes, base64-encoded
DHANADA_AUTH_KEK_BASE64=your-base64-encoded-32-byte-kek-here
# Optional: previous KEKs for decryption during rotation (oldest first)
# DHANADA_AUTH_KEK_PREVIOUS_BASE64_KEYS='["old-kek-1","old-kek-2"]'

# --- PAN HMAC Key ---
# Used for HMAC-SHA256 hashing of PAN numbers (uniqueness checks, not encryption)
# Must be at least 16 characters
DHANADA_AUTH_PAN_HMAC_KEY=your-pan-hmac-key-at-least-16-chars

# --- TOTP Configuration ---
DHANADA_AUTH_TOTP_ISSUER=Dhanada
DHANADA_AUTH_TOTP_WINDOW=1

# --- Account Lockout ---
DHANADA_AUTH_ACCOUNT_LOCKOUT_THRESHOLD=5
DHANADA_AUTH_ACCOUNT_LOCKOUT_MINUTES=15

# --- Session ---
DHANADA_AUTH_SESSION_TOKEN_BYTES=32

# --- Email / ZeptoMail (REQUIRED for password reset & verification) ---
# Get your API key from the ZeptoMail dashboard
DHANADA_AUTH_ZEPTOMAIL_API_KEY=your-zeptomail-api-key
# Verified sender email in ZeptoMail
DHANADA_AUTH_ZEPTOMAIL_FROM_EMAIL=noreply@dhanada.app

# --- Email Token TTLs ---
# Email verification token lifetime in minutes (default: 1440 = 24h)
DHANADA_AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
# Password reset token lifetime in minutes (default: 60)
DHANADA_AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# --- Application URLs ---
# Base URL used in email links (verification, password reset)
DHANADA_AUTH_BASE_URL=http://localhost:8000

# --- Document Storage ---
# Base directory for filesystem document storage (non-ID documents)
DHANADA_AUTH_DOCUMENT_STORAGE_PATH=./storage/documents

# --- Application ---
DHANADA_AUTH_ENVIRONMENT=development
DHANADA_AUTH_LOG_LEVEL=INFO
